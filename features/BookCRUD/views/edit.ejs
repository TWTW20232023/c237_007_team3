<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Book</title>
  <link rel="stylesheet" href="/css/bookcrud.css">
</head>
<body>
  <nav class="temp-navbar"><a href="/">Library Reservation</a><a href="/">Home</a><a href="/books">Manage Books</a><!-- TEMP: replace with shared navbar.ejs once Hazirah's UIIntegration merges --></nav>

  <div class="page-container">
    <p class="page-label">Book CRUD</p>
    <h1 class="page-heading">Edit Book</h1>

    <form action="/books/edit/<%= book.id %>" method="POST" class="form-card">
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" value="<%= book.title %>" required>
      </div>
      <div class="form-group">
        <label>Author</label>
        <input type="text" name="author" value="<%= book.author %>" required>
      </div>
      <div class="form-group">
        <label>Genre</label>
        <input type="text" name="genre" value="<%= book.genre %>">
      </div>
      <div class="form-group">
        <label>ISBN (auto-generated, not editable)</label>
        <input type="text" value="<%= book.isbn %>" disabled style="background-color: #e8e0cf;">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-gold">Save Changes</button>
        <a href="/books" class="btn btn-outline">Cancel</a>
      </div>

      <% if (qrCodeDataUrl) { %>
        <div class="qr-inline">
          <img src="<%= qrCodeDataUrl %>" alt="QR code for this book">
          <div class="qr-inline-text">
            <p class="page-label">Scan to Look Up</p>
            <p class="qr-url"><%= lookupUrl %></p>
          </div>
        </div>
      <% } %>
    </form>
  </div>

  <footer class="temp-footer">C237 CA2 — Library Book Reservation System<!-- TEMP: replace with shared footer.ejs once Hazirah's UIIntegration merges --></footer>
</body>
</html>
