<%- include('/partials/head', { title: 'Admin Dashboard' }) %>

    <div class="page-header">
        <div>
            <span class="eyebrow">Library Management</span>
            <h1>Admin Dashboard</h1>
            <p>
                View an overview of your library system, monitor reservations,
                and manage users from one place.
            </p>
        </div>
    </div>
    <!-- Dashboard Statistics -->
    <div class="dashboard-grid">
        <div class="dashboard-card dashboard-disabled">
            <span class="eyebrow">Users</span>
            <h3>Total Users</h3>
            <div class="dashboard-number">
                <%= totalUsers %>
            </div>
            <div class="dashboard-footer">
                Coming Soon
            </div>
        </div>
        <div class="dashboard-card dashboard-disabled">
            <span class="eyebrow">Administration</span>
            <h3>Total Admins</h3>
            <div class="dashboard-number">
                <%= totalAdmins %>
            </div>
            <div class="dashboard-footer">
                Coming Soon
            </div>
        </div>
        <div class="dashboard-card">
            <span class="eyebrow">Reservations</span>
            <h3>Total Reservations</h3>
            <div class="dashboard-number">
                <%= totalReservations %>
            </div>
            <div class="dashboard-footer">
                All-time
            </div>
        </div>
        <div class="dashboard-card">
            <span class="eyebrow">Pending</span>
            <h3>Pending Reservations</h3>
            <div class="dashboard-number">
                <%= pendingReservations %>
            </div>
            <div class="dashboard-footer">
                Awaiting your approval
            </div>
        </div>
        <div class="dashboard-card">
            <span class="eyebrow">Confirmed</span>
            <h3>Confirmed Reservations</h3>
            <div class="dashboard-number">
                <%= confirmedReservations %>
            </div>
            <div class="dashboard-footer">
                Approved / borrowed
            </div>
        </div>
        <div class="dashboard-card">
            <span class="eyebrow">Overdue</span>
            <h3>Overdue Reservations</h3>
            <div class="dashboard-number">
                <%= typeof overdueReservations !== "undefined" ? overdueReservations.length : 0 %>
            </div>
            <div class="dashboard-footer">
                Past the 2-week hold
            </div>
        </div>
    </div>
    <hr class="perforation">
    <!-- Newest Users -->
    <section>
        <h2>Newest Users</h2>
        <% if(newestUsers.length === 0){ %>
            <div class="empty-state">
                <h3>No Registered Users</h3>
                <p>
                    There are currently no registered users in the system.
                </p>
            </div>
        <% } else { %>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Role</th>
                        <th>Joined On</th>
                    </tr>
                </thead>
                <tbody>
                    <% newestUsers.forEach(user => { %>
                        <tr>
                            <td>
                                <%= user.username %>
                            </td>
                            <td>
                                <%= user.role %>
                            </td>
                            <td>
                                <%= new Date(user.created_at).toLocaleDateString() %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>
    <hr class="perforation">
    <!-- Recent Reservations -->
    <section>
        <h2>Recent Reservations</h2>
        <% if(reservations.length === 0){ %>
            <div class="empty-state">
                <h3>No Reservation Records</h3>
                <p>
                    There are currently no reservation records available.
                </p>
            </div>
        <% } else { %>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Reservation ID</th>
                        <th>Book Title</th>
                        <th>User</th>
                        <th>Reservation Date</th>
                        <th>Expiry Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% reservations.forEach(reservation => { %>

                        <tr>
                            <td><%= reservation.reservationId %></td>
                            <td><%= reservation.bookTitle %></td>
                            <td><%= reservation.username %></td>
                            <td><%= reservation.reservationDate %></td>
                            <td><%= reservation.expiryDate %></td>
                            <td>
                                <span class="status-badge <%= reservation.status.toLowerCase() %>">
                                    <%= reservation.status %>
                                </span>
                            </td>
                            <td>
                                <div class="table-actions">
                                    <% if (reservation.status === 'pending') { %>
                                        <form action="/reservations/<%= reservation.reservationId %>/approve" method="POST">
                                            <button type="submit" class="btn btn-primary">Approve</button>
                                        </form>
                                        <form action="/reservations/<%= reservation.reservationId %>/reject" method="POST">
                                            <button type="submit" class="btn btn-ghost">Reject</button>
                                        </form>
                                    <% } %>
                                    <form action="/reservations/<%= reservation.reservationId %>/delete" method="POST"
                                          onsubmit="return confirm('Delete this reservation?');">
                                        <button type="submit" class="btn btn-ghost">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>
    <hr class="perforation">
    <!-- Overdue List -->
    <section>
        <h2>Overdue List</h2>
        <% if (typeof overdueReservations === "undefined" || overdueReservations.length === 0) { %>
            <div class="empty-state">
                <h3>Nothing Overdue</h3>
                <p>
                    No approved reservations have passed their 2-week hold yet.
                </p>
            </div>
        <% } else { %>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Reservation ID</th>
                        <th>Book Title</th>
                        <th>User</th>
                        <th>Expired On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% overdueReservations.forEach(reservation => { %>
                        <tr>
                            <td><%= reservation.reservationId %></td>
                            <td><%= reservation.bookTitle %></td>
                            <td><%= reservation.username %></td>
                            <td><%= reservation.expiryDate %></td>
                            <td>
                                <div class="table-actions">
                                    <form action="/reservations/<%= reservation.reservationId %>/delete" method="POST"
                                          onsubmit="return confirm('Delete this reservation? This marks the book available again.');">
                                        <button type="submit" class="btn btn-ghost">Mark Returned / Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

<%- include('/partials/footer') %>
