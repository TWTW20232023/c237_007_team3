<%- include('../../../views/partials/header') %>

<div class="container mt-5">
    <h2 class="mb-4">My Book Reservations</h2>

    <% if (!reservations || reservations.length === 0) { %>

        <div class="alert alert-info">
            You haven't made any book reservations yet.
        </div>

    <% } else { %>

        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Book Title</th>
                        <th>Author</th>
                        <th>Reservation Date</th>
                        <th>Expiry Date</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    <% reservations.forEach(function(resItem) { %>

                        <tr>

                            <td>
                                <strong>
                                    <%= resItem.title || resItem.book_title %>
                                </strong>
                            </td>

                            <td>
                                <%= resItem.author || resItem.book_author %>
                            </td>

                            <td>
                                <% if (resItem.reservation_date) { %>
                                    <%= new Date(resItem.reservation_date).toLocaleDateString() %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>

                            <td>
                                <% if (resItem.expiry_date) { %>
                                    <%= new Date(resItem.expiry_date).toLocaleDateString() %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>

                            <td>

                                <% if (resItem.status === "pending") { %>

                                    <span class="badge bg-warning text-dark">
                                        Pending Approval
                                    </span>

                                <% } else if (resItem.status === "confirmed") { %>

                                    <span class="badge bg-success">
                                        Confirmed
                                    </span>

                                <% } else if (resItem.status === "expired") { %>

                                    <span class="badge bg-secondary">
                                        Expired
                                    </span>

                                <% } else if (resItem.status === "overdue") { %>

                                    <span class="badge bg-danger">
                                        Overdue
                                    </span>

                                <% } else if (resItem.status === "rejected") { %>

                                    <span class="badge bg-dark">
                                        Rejected
                                    </span>

                                <% } else { %>

                                    <span class="badge bg-light text-dark">
                                        <%= resItem.status %>
                                    </span>

                                <% } %>

                            </td>

                        </tr>

                    <% }); %>
                </tbody>

            </table>
        </div>

    <% } %>

    <div class="mt-3">
        <a href="/books" class="btn btn-primary">
            Back to Book Catalogue
        </a>
    </div>

</div>

<%- include('../../../views/partials/footer') %>