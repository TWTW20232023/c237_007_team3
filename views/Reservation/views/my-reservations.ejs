<%- include('/partials/head', { title: 'My Reservations' }) %>

<span class="eyebrow">Library System · Your Account</span>
<h1>My Reservations</h1>

<% if (!reservations || reservations.length === 0) { %>

<div class="empty-state">
    <h3>No Reservations Yet</h3>
    <p>You haven't reserved any books.</p>

    <a href="/catalog" class="btn btn-primary mt-3">
        Browse Books
    </a>
</div>

<% } else { %>

<table class="data-table">
    <thead>
        <tr>
            <th>Book</th>
            <th>Reservation Date</th>
            <th>Expiry Date</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>

    <% reservations.forEach(function(r){ %>

        <tr>

            <td>
                <strong><%= r.title || r.book_title %></strong><br>

                <span style="color:var(--ink-soft); font-size:.9rem;">
                    by <%= r.author || r.book_author %>
                </span>
            </td>

            <td>
                <%= new Date(r.reservation_date).toLocaleDateString() %>
            </td>

            <td>
                <%= new Date(r.expiry_date).toLocaleDateString() %>
            </td>

            <td>

                <% if (r.status === 'pending') { %>

                    <span class="stamp">
                        Pending
                    </span>

                <% } else if (r.status === 'confirmed') { %>

                    <span class="stamp available">
                        Confirmed
                    </span>

                <% } else if (r.status === 'overdue') { %>

                    <span class="status-pill is-out">
                        Overdue
                    </span>

                <% } else if (r.status === 'expired') { %>

                    <span class="status-pill is-out">
                        Expired
                    </span>

                <% } else { %>

                    <span class="status-pill">
                        <%= r.status %>
                    </span>

                <% } %>

            </td>

        </tr>

    <% }) %>

    </tbody>

</table>

<div style="margin-top:24px;">

    <a href="/catalog" class="btn btn-primary">
        ← Back to Book Catalogue
    </a>

</div>

<% } %>

<%- include('/partials/footer') %>