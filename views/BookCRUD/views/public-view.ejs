<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= book.title %> — Book Lookup</title>
  <link rel="stylesheet" href="/css/bookcrud.css">
</head>
<body>
  <div class="lookup-page">
    <p class="page-label">Book Lookup</p>

    <img src="/books/image/<%= book.id %>" alt=""
         class="lookup-cover"
         onerror="this.style.display='none'">

    <h1 class="page-heading lookup-title"><%= book.title %></h1>

    <div class="lookup-details">
      <div class="lookup-row">
        <span class="lookup-label">Author</span>
        <span class="lookup-value"><%= book.author %></span>
      </div>
      <div class="lookup-row">
        <span class="lookup-label">Genre</span>
        <span class="lookup-value"><%= book.genre %></span>
      </div>
      <div class="lookup-row">
        <span class="lookup-label">Status</span>
        <span class="status-badge <%= book.status === 'available' ? 'status-available' : 'status-reserved' %>">
          <%= book.status %>
        </span>
      </div>
    </div>

    <a href="/auth/login" class="btn btn-maroon lookup-cta">Log In to Reserve</a>

    <p class="lookup-footnote">Scanned from the library's book QR code</p>
  </div>
</body>
</html>
