<%- include('/partials/head', { title: 'Manage Books' }) %>
  <link rel="stylesheet" href="/css/bookcrud.css">

  <div class="page-container">
    <div class="page-header-row">
      <div>
        <p class="page-label">Book CRUD</p>
        <h1 class="page-heading">Manage Books</h1>
      </div>
      <a href="/books/add" class="btn btn-maroon">+ Add New Book</a>
    </div>

    <table class="book-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Author</th>
          <th>Genre</th>
          <th>ISBN</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach(book => { %>
          <tr>
            <td><%= book.id %></td>
            <td><%= book.title %></td>
            <td><%= book.author %></td>
            <td><%= book.genre %></td>
            <td><%= book.isbn %></td>
            <td>
              <span class="status-badge <%= book.status === 'available' ? 'status-available' : 'status-reserved' %>">
                <%= book.status %>
              </span>
            </td>
            <td class="actions-cell">
              <a href="/books/edit/<%= book.id %>" class="btn btn-gold btn-sm">Edit</a>

              <form action="/books/toggle/<%= book.id %>" method="POST">
                <button type="submit" class="btn btn-outline btn-sm">Toggle</button>
              </form>

              <form action="/books/delete/<%= book.id %>" method="POST"
                    onsubmit="return confirm('Delete this book?');">
                <button type="submit" class="btn btn-maroon btn-sm">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

<%- include('/partials/footer') %>
