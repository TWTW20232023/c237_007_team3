<%- include('/partials/head', { title: 'Manage Books' }) %>
  <link rel="stylesheet" href="/css/bookcrud.css">

  <div class="page-container">
    <div class="page-header-row">
      <div>
        <p class="page-label">Book CRUD</p>
        <h1 class="page-heading">Manage Books</h1>
      </div>
      <a href="/books/add" class="btn btn-maroon">+ Add New Book</a>
    </div>

    <table class="book-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Cover</th>
          <th>Title</th>
          <th>Author</th>
          <th>Genre</th>
          <th>ISBN</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach(book => { %>
          <tr>
            <td><%= book.id %></td>
            <td>
              <img src="/books/image/<%= book.id %>" alt="" class="book-thumb" onerror="this.style.display='none'">
            </td>
            <td><%= book.title %></td>
            <td><%= book.author %></td>
            <td><%= book.genre %></td>
            <td><%= book.isbn %></td>
            <td>
              <form action="/books/toggle/<%= book.id %>" method="POST" style="display:inline;">
                <button type="submit"
                        class="status-badge status-badge-clickable <%= book.status === 'available' ? 'status-available' : 'status-reserved' %>"
                        title="Click to mark as <%= book.status === 'available' ? 'Reserved' : 'Available' %>">
                  <%= book.status %>
                </button>
              </form>
            </td>
            <td class="actions-cell">
              <a href="/books/edit/<%= book.id %>" class="btn-icon-text btn-gold" title="Edit">&#9998; Edit</a>
              <a href="/reviews/<%= book.id %>" class="btn-icon-text btn-outline" title="Reviews">&#9733; Reviews</a>
              <form action="/books/delete/<%= book.id %>" method="POST"
                    onsubmit="return confirm('Delete this book?');" style="display:inline;">
                <button type="submit" class="btn-icon-text btn-maroon" title="Delete">&#128465; Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

<%- include('/partials/footer') %>
