<%- include('/partials/head', { title: 'Forgot Password' }) %>

<div class="auth-card">
  <span class="eyebrow">Library System · Reset Password</span>
  <h1>Forgot your password?</h1>

  <% if (typeof error !== 'undefined' && error && (!Array.isArray(error) || error.length)) { %>
    <div class="flash error"><%= error %></div>
  <% } %>

  <% if (typeof success !== 'undefined' && success && (!Array.isArray(success) || success.length)) { %>
    <div class="flash success"><%= success %></div>
  <% } %>

  <form action="/auth/forgot-password" method="POST">
    <p style="margin-bottom:1rem; font-size:0.95rem;">Enter your email address and we'll send you an OTP to reset your password.</p>
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" required>
    </div>
    <button class="btn btn-primary" type="submit">Send OTP</button>
  </form>

  <p style="margin-top:0.8rem; font-size:0.9rem;">
    Remember your password? <a href="/auth/login">Log in</a>
  </p>
</div>

<%- include('/partials/footer') %>