<%- include('/partials/head', { title: 'Log In' }) %>

<div class="auth-card">
  <span class="eyebrow">Library System · Member Login</span>
  <h1>Log in</h1>

  <% if (typeof error !== 'undefined' && error && (!Array.isArray(error) || error.length)) { %>
    <div class="flash error"><%= error %></div>
  <% } %>

  <form action="/auth/login" method="POST">
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= typeof oldInput !== 'undefined' ? oldInput.email : '' %>" required>
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required>
    </div>
    <button class="btn btn-primary" type="submit">Log in</button>
  </form>

  <p style="margin-top:1.2rem; font-size:0.9rem;">
    Don't have an account? <a href="/auth/signup">Sign up</a>
  </p>
</div>

<%- include('/partials/footer') %>
