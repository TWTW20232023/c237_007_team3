<%- include('/partials/head') %>

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4>Verify OTP</h4>
                </div>
                <div class="card-body">
                    <% if (error) { %>
                        <div class="alert alert-danger"><%= error %></div>
                    <% } %>

                    <p>An OTP has been sent to your email. Please enter it below.</p>

                    <form action="/auth/verify-otp" method="POST">
                        <div class="mb-3">
                            <label for="otp" class="form-label">One-Time Password</label>
                            <input type="text" class="form-control" id="otp" name="otp" maxlength="6" required placeholder="Enter 6-digit OTP">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Verify OTP</button>
                    </form>

                    <div class="mt-3 text-center">
                        <a href="/auth/forgot-password">Request a new OTP</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('/partials/footer') %>