<%# features/Reservation (Min)/views/my-reservations.ejs %>

<h1>My Reservations</h1>

<% if (reservations.length === 0) { %>
  <p>You have no reservations yet.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>Title</th><th>Author</th><th>Reserved On</th><th>Expires On</th><th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% reservations.forEach(r => { %>
        <tr>
          <td><%= r.title %></td>
          <td><%= r.author %></td>
          <td><%= new Date(r.reservation_date).toLocaleDateString() %></td>
          <td><%= new Date(r.expiry_date).toLocaleDateString() %></td>
          <td><span class="badge status-<%= r.status %>"><%= r.status %></span></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
